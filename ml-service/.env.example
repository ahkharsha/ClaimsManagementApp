# ============================================================
# InsuranceIQ Intelligence Service — Environment Variables
# ============================================================
# Copy this file to .env and customize as needed.

# ── App ────────────────────────────────────────────────────
APP_NAME=InsuranceIQ Intelligence Service
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# ── Database ───────────────────────────────────────────────
# SQLite (default — standalone testing):
DATABASE_URL=sqlite:///./insuranceiq.db
# PostgreSQL (production — shared with Spring Boot):
# DATABASE_URL=postgresql://username:password@localhost:5432/insuranceiq

DB_ECHO=False

# ── Fraud Detection ───────────────────────────────────────
# Options: RULE_BASED | ML
FRAUD_DETECTION_MODE=RULE_BASED
ML_MODEL_PATH=ml/fraud_model.pkl

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# ── File Paths ────────────────────────────────────────────
DATA_DIR=data/sample
UPLOAD_DIR=data/uploads

# ── External Services ────────────────────────────────────────
NOTIFICATION_SERVICE_URL=http://localhost:3001
SERVICE_SECRET=InsuranceIQInternalServiceSecret2024
SPRING_BOOT_URL=http://localhost:8080
