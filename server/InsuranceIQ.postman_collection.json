              "mode": "raw",
              "raw": "{\n  \"policy_id\": \"POL-2024-001\",\n  \"customer_id\": 1,\n  \"claim_type\": \"Health\",\n  \"incident_date\": \"2025-01-15\",\n  \"claim_amount\": 50000,\n  \"description\": \"Emergency treatment\"\n}"
            }
          }
        },
        {
          "name": "Update Claim Status",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/claims/CLM-2024-001",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Fraud Prediction",
      "item": [
        {
          "name": "Predict Fraud",
          "request": { "method": "POST", "url": "{{baseUrl}}/predict/fraud/CLM-2024-003" }
        },
        {
          "name": "Get All Predictions",
          "request": { "method": "GET", "url": "{{baseUrl}}/predict/fraud/all" }
        },
        {
          "name": "Get Flagged Predictions",
          "request": { "method": "GET", "url": "{{baseUrl}}/predict/fraud/flagged" }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Dashboard Summary",
          "request": { "method": "GET", "url": "{{baseUrl}}/analytics/dashboard-summary" }
